# =============================================================
# SecureFlow .gitignore
# =============================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# VS Code
.vscode/

# Logs
*.log

# Local artifacts — keep locally only
screenshots/
reports/gitleaks-local.json
