# --- AWS Credentials (IV-04) ---
# Risk: Full AWS account compromise if leaked to public repository
# Exploitation: Automated scanners detect AKIA patterns within minutes
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
 
# --- Database Credentials (IV-01, IV-03, IV-04) ---
# Risk: Direct read/write access to all customer account data
AUTH_DB_PASSWORD=authpass123
AUTH_DB_USER=authuser
AUTH_DB_NAME=authdb
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
 
TRANSACTION_DB_PASSWORD=txpass123
TRANSACTION_DB_USER=txuser
TRANSACTION_DB_NAME=transactiondb
TRANSACTION_DB_HOST=transaction-db
TRANSACTION_DB_PORT=5432
 
# --- JWT Secret (AV-07, IV-03, IV-04) ---
# Risk: Attacker can forge login tokens and impersonate any user including admin
# Value matches what is hardcoded in docker-compose.yml
JWT_SECRET=super-secret-key-123
 
# --- Session Secret (FV-03, IV-03, IV-04) ---
# Risk: Attacker can forge browser session cookies and hijack any active session
# Value matches what is hardcoded in docker-compose.yml
SESSION_SECRET=changeme
 
# --- SonarQube Token (IV-04) ---
# Risk: Attacker can read code scan results, suppress findings, or disable scanning
SONAR_TOKEN=sqp_examplesonarqubetoken1234567890abcdef
 
# --- Service URLs ---
AUTH_SERVICE_URL=http://auth-service:5001
TRANSACTION_SERVICE_URL=http://transaction-service:5002
 
